<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Poitrasson</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<header>
  <div class="container">
    <h1>Poitrasson</h1>
    <nav>
      <a href="index.html">Accueil</a>
      <a href="services.html">Services</a>
      <a href="a-propos.html">À propos</a>
      <a href="contact.html" class="btn">Contact</a>
    </nav>
  </div>
</header>

<section class="hero">
  <div class="container">
    <h2>Votre partenaire en transport et logistique</h2>
    <p>Une expertise reconnue pour des solutions fiables et efficaces.</p>
    <a href="contact.html" class="btn">Demander un devis</a>
  </div>
</section>

<section class="services-preview container">
  <h2>Nos services</h2>
  <div class="grid">
    <div class="card">Transport</div>
    <div class="card">Logistique</div>
    <div class="card">Distribution</div>
  </div>
</section>

<section class="about container">
  <h2>Une entreprise de confiance</h2>
  <p>
    Forts de notre expérience, nous accompagnons nos clients avec des solutions adaptées,
    en garantissant qualité, réactivité et professionnalisme.
  </p>
</section>

<footer>
  <p>© Poitrasson - Tous droits réservés</p>
</footer>

</body>
</html>
